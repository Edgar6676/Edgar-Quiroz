<!DOCTYPE html>
<html>
<head>
  <title>Edgar Quiroz Resume</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://www.w3schools.com/w3css/5/w3.css">
  <link rel='stylesheet' href='https://fonts.googleapis.com/css?family=Roboto'>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <style>
    html,body,h1,h2,h3,h4,h5,h6 {font-family: "Roboto", sans-serif}
  </style>
</head>
<body class="w3-light-grey">

<div class="w3-content w3-margin-top" style="max-width:1400px;">
  <div class="w3-row-padding">

    <!-- LEFT COLUMN -->
    <div class="w3-third">
      <div class="w3-white w3-text-grey w3-card-4">

        <div class="w3-container">
          <h2>Edgar Quiroz</h2>
          <p><i class="fa fa-home fa-fw w3-margin-right w3-large w3-text-teal"></i>Los Angeles, CA</p>
          <p><i class="fa fa-envelope fa-fw w3-margin-right w3-large w3-text-teal"></i>Love.maze.enthusiast@gmail.com</p>
          <p><i class="fa fa-phone fa-fw w3-margin-right w3-large w3-text-teal"></i>(213) 917-6619</p>
          <hr>

          <p class="w3-large"><b><i class="fa fa-asterisk fa-fw w3-margin-right w3-text-teal"></i>Core Skills</b></p>
          <p>Team Collaboration</p>
          <p>Leadership & Team Support</p>
          <p>Time Management & Reliability</p>
          <p>Bilingual: English & Spanish</p>

          <br>

          <p class="w3-large w3-text-theme"><b><i class="fa fa-globe fa-fw w3-margin-right w3-text-teal"></i>Languages</b></p>
          <p>English</p>
          <p>Spanish</p>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="w3-twothird">

      <!-- WORK EXPERIENCE -->
      <div class="w3-container w3-card w3-white w3-margin-bottom">
        <h2 class="w3-text-grey w3-padding-16">
          <i class="fa fa-suitcase fa-fw w3-margin-right w3-xxlarge w3-text-teal"></i>
          Work Experience
        </h2>

        <div class="w3-container">
          <h5 class="w3-opacity"><b>Assistant Technician — Dubal Appliance Service</b></h5>
          <h6 class="w3-text-teal">September 2019 — Current</h6>
          <p>
            • Delivered high-quality customer service<br>
            • Assisted in appliance sales (refrigerators, washers, dryers)<br>
            • Collaborated with lead technician to troubleshoot and repair appliances from SEARS
          </p>
          <hr>
        </div>

        <div class="w3-container">
          <h5 class="w3-opacity"><b>Unarmed Security Guard — Able Solutions</b></h5>
          <h6 class="w3-text-teal">June 2025 — July 2025</h6>
          <p>
            • Patrolled assigned areas to ensure community safety<br>
            • Monitored and reported incidents<br>
            • Assisted pedestrians and residents
          </p>
          <hr>
        </div>

        <div class="w3-container">
          <h5 class="w3-opacity"><b>After School Program Leader — LA’s Best</b></h5>
          <h6 class="w3-text-teal">November 2024 — July 2025</h6>
          <p>
            • Created a safe and supportive student environment<br>
            • Helped students with homework and academics<br>
            • Led enrichment activities and teamwork exercises<br>
            • Communicated with students, parents, and staff
          </p>
        </div>
      </div>

      <!-- EDUCATION -->
      <div class="w3-container w3-card w3-white w3-margin-bottom">
        <h2 class="w3-text-grey w3-padding-16">
          <i class="fa fa-certificate fa-fw w3-margin-right w3-xxlarge w3-text-teal"></i>
          Education
        </h2>

        <div class="w3-container">
          <h5 class="w3-opacity"><b>California State University Long Beach</b></h5>
          <h6 class="w3-text-teal">August 2025 — Present</h6>
          <p>Electrical Engineering Major<br>Honors Scholar | BESST/BEACH XP Scholar</p>
          <hr>
        </div>

        <div class="w3-container">
          <h5 class="w3-opacity"><b>Mervyn M. Dymally High School</b></h5>
          <p>Biomedical Science & Research Magnet<br>Honors Student | Biomedical Lab Assistant</p>
        </div>
      </div>

      <!-- VOLUNTEER -->
      <div class="w3-container w3-card w3-white">
        <h2 class="w3-text-grey w3-padding-16">
          <i class="fa fa-users fa-fw w3-margin-right w3-xxlarge w3-text-teal"></i>
          Volunteer Experience
        </h2>

        <div class="w3-container">
          <p>
            • Leadership Member — Mervyn M. Dymally High School (2023–2024)<br>
            • Advocate Behavior Program (2023)<br>
            • Biomedical Lab Assistant (2025)
          </p>
        </div>
      </div>

    </div>
  </div>
</div>

</body>
</html>
